{
  "name": "smartseason-backend",
  "version": "1.0.0",
  "description": "SmartSeason Field Monitoring System Backend API",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "gen": "drizzle-kit generate",
    "push": "drizzle-kit generate && drizzle-kit push",
    "studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:pull": "drizzle-kit pull",
    "seed": "tsx src/drizzle/seed.ts",
    "seed:reset": "tsx src/drizzle/seed.ts --reset"
  },
  "keywords": [
    "smartseason",
    "field-monitoring",
    "drizzle",
    "express",
    "postgresql"
  ],
  "author": "Boaz Lee-Limo",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}